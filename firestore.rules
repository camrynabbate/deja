rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Saves, likes, and styleboards are visible only to their owner.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Signed-in users can browse the catalog. Catalog changes require the
    // same Firebase custom claim used by the protected in-app admin route.
    match /clothing_items/{itemId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.admin == true;
    }

    // Legacy global search records can contain user activity. The app no
    // longer uses this collection, so client access is closed.
    match /dupe_searches/{searchId} {
      allow read, write: if false;
    }
  }
}
